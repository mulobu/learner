# App
APP_NAME=Learner
DEBUG=false
API_V1_PREFIX=/api/v1

# Database (Neon)
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/<db_name>

# Storage (Cloudflare R2)
STORAGE_MODE=r2
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100
R2_BUCKET_NAME=learner-pdfs
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=@cf/openai/gpt-oss-120b

# CORS (set your frontend domains for Cloudflare Pages/custom domains)
CORS_ORIGINS=["https://your-frontend-domain.com","http://localhost:5173"]

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.learner.prod
# Optional override; by default issuer is derived from AUTH0_DOMAIN
AUTH0_ISSUER=
# Configure an Auth0 Action to add roles to this claim in access tokens
AUTH0_ROLES_CLAIM=https://learner.app/roles
AUTH0_ADMIN_ROLE=admin
AUTH0_JWKS_CACHE_SECONDS=300
AUTH0_USERINFO_TIMEOUT_SECONDS=5

# Optional content APIs
YOUTUBE_API_KEY=

# Rate limiting (requests per minute)
LLM_RATE_LIMIT=10
YOUTUBE_RATE_LIMIT=5

# CI/CD deployment (GitHub Actions Secrets; not used by app runtime)
FLY_API_TOKEN=
