# Frontend note: all VITE_* values are bundled into client JS and are public.
# Never put secrets in this file.
VITE_API_URL=http://localhost:8000/api/v1
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_spa_client_id
VITE_AUTH0_AUDIENCE=https://api.learner.prod
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/login

# CI/CD deployment (GitHub Actions; not read by Vite app runtime)
# Repository Variable:
CLOUDFLARE_PAGES_PROJECT_NAME=
# Repository Secrets:
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_API_TOKEN=
