# Frontend note: all VITE_* values are bundled into client JS and are public.
# Never put secrets in this file.
#
# GitHub Actions (frontend-cloudflare-pages.yml) reads these from GitHub Variables.
VITE_API_URL=http://localhost:8000/api/v1
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_spa_client_id
VITE_AUTH0_AUDIENCE=https://api.learner.prod
# Optional: app defaults to ${window.location.origin}/login when not set.
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/login

# GitHub Actions deploy config (not read by Vite app runtime)
# GitHub Variable:
CLOUDFLARE_PAGES_PROJECT_NAME=learner-frontend
# GitHub Secrets:
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_API_TOKEN=
